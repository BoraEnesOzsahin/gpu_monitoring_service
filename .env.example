# RECKON Service Configuration
# Copy this file to .env and update the values

# EMS Server Configuration
EMS_API_URL=http://127.0.0.1:8000

# Server Port (for mock_ems_server.py)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Client Configuration
DEFAULT_HEARTBEAT_INTERVAL=60
RETRY_DELAY=60

# Watchdog Configuration
WATCHDOG_TIMEOUT=120

# Secrets file path
SECRETS_FILE=secrets.json

# Power Control Security Settings
# Enable/disable remote power control (true/false)
ALLOW_REMOTE_POWER_CONTROL=true

# Rate limiting for power adjustments
# Maximum number of power changes allowed within the time period
RATE_LIMIT_MAX_CHANGES=5

# Time period in seconds for rate limiting (default: 300 = 5 minutes)
RATE_LIMIT_PERIOD_SECONDS=300

# Audit log file for power adjustments
POWER_AUDIT_LOG=power_audit.log
